# Copy this file to .env and fill in real values. .env is gitignored.

# Helium paywall API key (JWT from the Helium dashboard)
EXPO_PUBLIC_HELIUM_API_KEY=REPLACE_ME

# Trigger name configured for your paywall
EXPO_PUBLIC_HELIUM_TRIGGER=REPLACE_ME

# Apple Team ID used to code-sign device builds. Only required for
# `expo run:ios --device`; simulator builds don't need it.
APPLE_TEAM_ID=REPLACE_ME
